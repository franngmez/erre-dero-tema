<section class="relative overflow-hidden">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 pb-16 pt-14 md:grid-cols-[1.05fr_1fr] md:gap-16 md:px-8 md:pb-24 md:pt-20">
    <div class="flex flex-col justify-center">
      <span class="eyebrow">Slow crochet · Edición limitada</span>
      <h1 class="mt-5 font-serif text-5xl leading-[1.02] tracking-tight md:text-7xl">
        Bolsos que se tejen<br />
        <span class="italic text-accent">nudo a nudo,</span> con tiempo.
      </h1>
      <p class="mt-6 max-w-lg text-base leading-relaxed text-muted-foreground">
        ErredeRo nace de las manos de Rocío Copano de la Vega. Cada pieza es
        única, hecha a crochet con materiales premium y sin prisa. Slow fashion,
        de verdad.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a href="/collections/all" class="group inline-flex items-center gap-3 bg-primary px-7 py-4 text-sm tracking-wide text-primary-foreground transition-colors hover:bg-primary/90">
          Ver la colección
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
        <a href="/pages/personaliza" class="inline-flex items-center gap-2 border-b border-foreground/60 pb-1 text-sm tracking-wide text-foreground hover:border-accent hover:text-accent">
          Diseña el tuyo a medida
        </a>
      </div>

      <dl class="mt-14 grid grid-cols-3 gap-6 border-t border-border/60 pt-8 text-xs">
        <div>
          <dt class="eyebrow">Piezas al año</dt>
          <dd class="mt-2 font-serif text-2xl">120</dd>
        </div>
        <div>
          <dt class="eyebrow">Horas por bolso</dt>
          <dd class="mt-2 font-serif text-2xl">18 — 40</dd>
        </div>
        <div>
          <dt class="eyebrow">Hecho en</dt>
          <dd class="mt-2 font-serif text-2xl">España</dd>
        </div>
      </dl>
    </div>

    <div class="relative">
      <div class="relative aspect-[4/5] overflow-hidden bg-secondary">
        <img
          src="https://cdn.shopify.com/s/files/1/0000/0000/files/hero-bag.jpg?v=1"
          alt="Bolso de crochet ErredeRo con asas de bambú"
          width="1600"
          height="1920"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="absolute -bottom-6 -left-6 hidden max-w-[220px] bg-cream p-5 shadow-sm ring-1 ring-border/60 md:block">
        <p class="eyebrow">N.º 04 / 12</p>
        <p class="mt-2 font-serif text-lg leading-tight">Tote Luna · algodón crudo</p>
        <p class="mt-1 text-xs text-muted-foreground">
          32 horas de trabajo. Última unidad en stock.
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero ErreDerO",
  "settings": [],
  "presets": [
    {
      "name": "Hero ErreDerO"
    }
  ]
}
{% endschema %}
